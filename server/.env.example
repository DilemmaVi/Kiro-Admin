PORT=3001
JWT_SECRET=kiro-admin-secret-key-change-this-in-production
CORS_ORIGIN=http://localhost:5173

# OAuth 配置
OAUTH_REDIRECT_URI=http://localhost:3001/api/auth/oauth/callback

# 部署到 HTTPS 跨域场景（Vercel + Render）时建议打开：
# COOKIE_SECURE=true
# COOKIE_SAMESITE=none
# TRUST_PROXY=true

# 数据库类型：sqlite 或 postgres
DB_TYPE=sqlite

# SQLite 配置（当 DB_TYPE=sqlite 时使用）
# SQLite 存储路径（Render 可用持久化磁盘路径 /var/data/kiro.db）
# DB_PATH=./data/kiro.db

# PostgreSQL 配置（当 DB_TYPE=postgres 时使用）
# 
# Supabase 配置示例：
# - 使用 Pooler 连接（推荐用于 Serverless）
#   Host: aws-0-{region}.pooler.supabase.com
#   Port: 6543
#   User: postgres.{project-ref}  （注意：包含 postgres. 前缀）
#   Database: postgres
#   SSL: 默认启用（云数据库必需）
#
# - 使用直连（用于长连接）
#   Host: db.{project-ref}.supabase.co
#   Port: 5432
#   User: postgres
#   Database: postgres
#   SSL: 默认启用（云数据库必需）
#
DB_POSTGRESDB_HOST=localhost
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=postgres
DB_POSTGRESDB_USER=postgres
DB_POSTGRESDB_PASSWORD=
DB_POSTGRESDB_SCHEMA=public
# SSL 配置（默认启用，本地开发可设置为 false）
# DB_POSTGRESDB_SSL=false
